# ─────────────────────────────────────────────────────
# ELIMS Server Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ─────────────────────────────────────────────────────

# Runtime
NODE_ENV=production
PORT=8080

# When behind Render/Fly/Heroku/nginx, set this to 1 so secure cookies work
TRUST_PROXY=1

# ─────────────────────────────────────────────────────
# Admin authentication
# ─────────────────────────────────────────────────────
ADMIN_USER=admin

# PREFERRED: bcrypt hash. Generate with:
#   npm run hash-password -- "your-strong-password"
ADMIN_PASS_HASH=

# Fallback (DEV ONLY). Leave blank if ADMIN_PASS_HASH is set.
ADMIN_PASS=

# ─────────────────────────────────────────────────────
# Sessions — REQUIRED in production
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────────────
SESSION_SECRET=

# ─────────────────────────────────────────────────────
# SMTP for application notification emails
# ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─────────────────────────────────────────────────────
# WhatsApp business number (no +, with country code)
# Used by the floating widget in js/main.js
# ─────────────────────────────────────────────────────
WHATSAPP_NUMBER=918075765602
